:80 {
	# Line 1 above is the site address and is rewritten by quickstart.sh:
	#   - HTTP mode (local hostname / IP): ":80" serves every host on port 80,
	#     so the dashboard is reachable by IP or hostname with no DNS/TLS setup.
	#   - HTTPS mode (real FQDN): becomes "https://your.domain" for automatic TLS.
	encode gzip zstd
	request_body {
		max_size 100MB
	}

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "same-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# OpenCuttles is a single binary that serves both the API and the embedded
	# SPA, so Caddy only needs to terminate TLS and forward everything upstream.
	reverse_proxy 127.0.0.1:8080
}
