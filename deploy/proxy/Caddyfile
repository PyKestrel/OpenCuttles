# Default: serve over HTTP on every host/IP on port 80 so the dashboard is
# reachable by IP or hostname with zero DNS/TLS setup. quickstart.sh rewrites
# this first line to "https://your.domain" when you deploy with a real FQDN.
:80 {
	encode gzip zstd
	request_body {
		max_size 100MB
	}

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "same-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# OpenCuttles is a single binary that serves both the API and the embedded
	# SPA, so Caddy only needs to terminate TLS and forward everything upstream.
	reverse_proxy 127.0.0.1:8080
}
