[Unit]
Description=OpenCuttles agent sidecar (Flue harness + local MiniCPM5 cognitive core)
After=network.target opencuttles-api.service ollama.service
Wants=opencuttles-api.service

[Service]
Type=simple
User=opencuttles
Group=opencuttles
WorkingDirectory=/opt/opencuttles/agent
EnvironmentFile=-/etc/opencuttles/agent.env
# The OpenCuttles API reverse-proxies /agents/* to this port.
Environment=PORT=8790
# Build the bundle first: `make build-agent` (or `npx flue build --target node`)
# produces dist/server.mjs. `scripts/ubuntu/update.sh` rebuilds it on every
# deploy so this never runs a stale bundle.
ExecStart=/usr/bin/node dist/server.mjs
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=full
UMask=0077

[Install]
WantedBy=multi-user.target
