OPENCUTTLES_LISTEN=127.0.0.1:8080
OPENCUTTLES_DB=/var/lib/opencuttles/opencuttles.db
OPENCUTTLES_ALLOWED_ORIGIN=https://testral.cloud
OPENCUTTLES_SECURE_COOKIES=1
OPENCUTTLES_BOOTSTRAP_TOKEN=change-this-before-first-start
OPENCUTTLES_TRUST_PROXY_HEADERS=1
OPENCUTTLES_EXECUTE_CVD=0
# Host-wide cuttlefish-operator HTTPS port used for the WebRTC console.
# Current Cuttlefish uses 1443; older builds used 8443.
OPENCUTTLES_OPERATOR_PORT=1443
OPENCUTTLES_IMAGE_ROOT=/var/lib/opencuttles/images
OPENCUTTLES_DEFAULT_IMAGE_PATH=/var/lib/opencuttles/images/default
OPENCUTTLES_CVD_BUILD=aosp-android-latest-release/aosp_cf_x86_64_only_phone-userdebug
# Shared secret the local agent (Flue sidecar) presents to the MCP endpoint at
# /api/v1/mcp. If unset, MCP requires a session with the "control" permission.
# Also gates GET /api/v1/agent/runtime, from which the sidecar reads the
# admin-configured model + decrypted API key.
OPENCUTTLES_MCP_TOKEN=change-this-to-a-random-secret
# Master key (base64, 32 bytes) for encrypting agent provider API keys at rest.
# Generate with:  openssl rand -base64 32
# If unset, the dashboard can still select keyless providers (local Ollama) but
# refuses to store an API key.
OPENCUTTLES_SECRET_KEY=change-this-generate-with-openssl-rand-base64-32
# Vision sidecar (Florence-2): agent vision tools + test runner.
OPENCUTTLES_VISION_URL=http://127.0.0.1:8791
# Test-run evidence (per-step screenshots, session video).
OPENCUTTLES_ARTIFACT_ROOT=/var/lib/opencuttles/artifacts
