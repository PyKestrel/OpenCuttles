# Backend
backend/opencuttles.db
backend/*.db
backend/bin/

# Local dev state created by scripts/dev/start.sh and the api-local launch
# config (SQLite DB, fetched images, run artifacts).
data/

# Packaged release output (make package)
dist/

# Frontend
frontend/dist/
frontend/node_modules/

# Embedded frontend build (staged by the Makefile, keep only the placeholder)
backend/internal/web/dist/*
!backend/internal/web/dist/.gitkeep

# Embedded runner binaries (cross-compiled by the Makefile, keep the placeholder)
backend/internal/runnerdist/bin/*
!backend/internal/runnerdist/bin/.gitkeep

# Local editor and OS files
.DS_Store
Thumbs.db
.env
