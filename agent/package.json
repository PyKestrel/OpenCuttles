{
  "name": "opencuttles-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Flue-harnessed cognitive-core agent that drives Android devices via the OpenCuttles MCP tools.",
  "scripts": {
    "dev": "flue dev --port 8790",
    "build": "flue build --target node",
    "start": "node dist/server.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.9",
    "@flue/sdk": "1.0.0-beta.9",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@flue/cli": "^1.0.0-beta.9",
    "typescript": "^5.6.0"
  }
}
