# OpenCuttles agent sidecar configuration.

# The OpenCuttles MCP endpoint (same host). Device tools are served here.
OPENCUTTLES_MCP_URL=http://127.0.0.1:8080/api/v1/mcp
# Must match OPENCUTTLES_MCP_TOKEN in the backend env so the sidecar can auth.
OPENCUTTLES_MCP_TOKEN=

# Model specifier resolved via Pi's models.json (see agent/models.json, which is
# copied to ~/.pi/agent/models.json). Points at the local Ollama MiniCPM5.
OPENCUTTLES_AGENT_MODEL=ollama/minicpm5

# Port the Flue agent HTTP server listens on (proxied to the SPA under /agents).
PORT=8790
