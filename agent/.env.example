# OpenCuttles agent sidecar configuration.

# The OpenCuttles MCP endpoint (same host). Device tools are served here.
OPENCUTTLES_MCP_URL=http://127.0.0.1:8080/api/v1/mcp
# Must match OPENCUTTLES_MCP_TOKEN in the backend env so the sidecar can auth.
OPENCUTTLES_MCP_TOKEN=

# Ollama model the agent runs on. IMPORTANT: Ollama's default context (4096) is
# too small for the system prompt + tool schemas (~6K tokens); derive a variant
# with a larger num_ctx and point at it:
#   printf 'FROM openbmb/minicpm5\nPARAMETER num_ctx 16384\n' > Modelfile
#   ollama create minicpm5-16k -f Modelfile
OPENCUTTLES_AGENT_MODEL=ollama/minicpm5-16k

# Port the Flue agent HTTP server listens on (proxied to the SPA under /agents).
PORT=8790
