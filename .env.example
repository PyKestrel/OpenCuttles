OPENCUTTLES_LISTEN=127.0.0.1:8080
OPENCUTTLES_DB=./data/dev/opencuttles.db
OPENCUTTLES_ALLOWED_ORIGIN=http://localhost:5173
OPENCUTTLES_SECURE_COOKIES=0
OPENCUTTLES_EXECUTE_CVD=0
OPENCUTTLES_IMAGE_ROOT=./data/images
# Shared secret the local agent (Flue sidecar) presents to the MCP endpoint at
# /api/v1/mcp (Authorization: Bearer <token> or X-MCP-Token). If unset, the MCP
# endpoint falls back to requiring a session with the "control" permission.
OPENCUTTLES_MCP_TOKEN=
# Vision sidecar (Florence-2), used by the agent's vision MCP tools (tap_element,
# find_element, ask_screen) and the test runner. Defaults to this if unset.
OPENCUTTLES_VISION_URL=http://127.0.0.1:8791
