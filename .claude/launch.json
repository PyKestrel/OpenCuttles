{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend-appliance",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--host", "127.0.0.1"],
      "cwd": "frontend",
      "env": {
        "OC_API_TARGET": "http://10.1.0.104"
      },
      "port": 5173
    },
    {
      "name": "api-local",
      "runtimeExecutable": "go",
      "runtimeArgs": ["run", "./cmd/opencuttles-api"],
      "cwd": "backend",
      "env": {
        "OPENCUTTLES_LISTEN": "127.0.0.1:8080",
        "OPENCUTTLES_DB": "../data/dev/opencuttles.db",
        "OPENCUTTLES_IMAGE_ROOT": "../data/images",
        "OPENCUTTLES_SECURE_COOKIES": "0",
        "OPENCUTTLES_EXECUTE_CVD": "0",
        "OPENCUTTLES_ALLOWED_ORIGIN": "http://localhost:5173"
      },
      "port": 8080
    },
    {
      "name": "frontend-local",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--host", "127.0.0.1"],
      "cwd": "frontend",
      "env": {
        "OC_API_TARGET": "http://127.0.0.1:8080"
      },
      "port": 5173
    }
  ]
}
